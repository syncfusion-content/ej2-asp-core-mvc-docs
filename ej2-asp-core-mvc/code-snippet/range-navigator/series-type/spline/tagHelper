
@{
   var value = new object[] { new DateTime(2006, 01, 01), new DateTime(2007, 12, 31) };
}
 <ejs-rangenavigator id="rangeNavigator" valueType="DateTime" labelFormat="yyyy" value="value">
                <e-rangenavigator-tooltip enable="true" format="yyyy/MM/dd"></e-rangenavigator-tooltip>
                <e-rangenavigator-rangenavigatorseriescollection>
                    <e-rangenavigator-rangenavigatorseries xName="x" yName="y" dataSource="ViewBag.dataSource" type="Spline">
                    </e-rangenavigator-rangenavigatorseries>
                </e-rangenavigator-rangenavigatorseriescollection>
</ejs-rangenavigator>
