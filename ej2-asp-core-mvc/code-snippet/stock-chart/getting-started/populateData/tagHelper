<ejs-stockchart id="stockchart" load="stockload">
	<e-stockchart-primaryxaxis valueType="DateTime">
    </e-stockchart-primaryxaxis>
	<e-stockchart-series-collection>
		<e-stockchart-series 
            type="Candle" xName="x" open="open" high="high" low="low" close="close" name="Apple">
	</e-stockchart-series-collection>
</ejs-stockchart>

<script src="~/chart/financial-data.js"></script>
<script>
	var data = chartData;
	function stockload(args) {
		args.stockChart.series[0].dataSource = data;
	}
</script>