<ejs-chart id="container" crosshairLabelRender="crosshairLabelRender">

    <e-chart-primaryxaxis valueType="Category">
        <e-crosshairtooltip enable="true"></e-crosshairtooltip>
    </e-chart-primaryxaxis>

    <e-chart-primaryyaxis>
        <e-crosshairtooltip enable="true"></e-crosshairtooltip>
    </e-chart-primaryyaxis>

    <e-chart-crosshairsettings enable="true"></e-chart-crosshairsettings>

    <e-series-collection>

        <e-series dataSource="ViewBag.dataSource"
                  xName="x"
                  yName="y"
                  name="Series"
                  type="@Syncfusion.EJ2.Charts.ChartSeriesType.Line">
        </e-series>

    </e-series-collection>

</ejs-chart>