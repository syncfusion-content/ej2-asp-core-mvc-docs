@Html.EJS().Chart("container")
.PrimaryXAxis(px => px.ValueType(Syncfusion.EJ2.Charts.ValueType.Category))
.LegendSettings(l => l.Visible(true))
.Series(series =>
{
    series.DataSource(ViewBag.vietnamData)
        .XName("x").YName("y").Name("Vietnam")
        .Type(Syncfusion.EJ2.Charts.ChartSeriesType.Line)
        .Marker(m => m.Visible(true))
        .LabelSettings(ls => ls.Visible(true))
        .Add();

    series.DataSource(ViewBag.indonesiaData)
        .XName("x").YName("y").Name("Indonesia")
        .Type(Syncfusion.EJ2.Charts.ChartSeriesType.Line)
        .Marker(m => m.Visible(true))
        .LabelSettings(ls => ls.Visible(true))
        .Add();

    series.DataSource(ViewBag.franceData)
        .XName("x").YName("y").Name("France")
        .Type(Syncfusion.EJ2.Charts.ChartSeriesType.Line)
        .Marker(m => m.Visible(true))
        .LabelSettings(ls => ls.Visible(true))
        .Add();

    series.DataSource(ViewBag.polandData)
        .XName("x").YName("y").Name("Poland")
        .Type(Syncfusion.EJ2.Charts.ChartSeriesType.Line)
        .Marker(m => m.Visible(true))
        .LabelSettings(ls => ls.Visible(true))
        .Add();

    series.DataSource(ViewBag.mexicoData)
        .XName("x").YName("y").Name("Mexico")
        .Type(Syncfusion.EJ2.Charts.ChartSeriesType.Line)
        .Marker(m => m.Visible(true))
        .LabelSettings(ls => ls.Visible(true))
        .Add();
})
.Render()