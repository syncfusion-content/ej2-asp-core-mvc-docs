@Html.EJS().Chart("container")
.PrimaryXAxis(px =>
    px.ValueType(Syncfusion.EJ2.Charts.ValueType.Category)
)
.LegendSettings(l => l.Visible(true))
.Series(series =>
{
    series.Type(Syncfusion.EJ2.Charts.ChartSeriesType.Line)
        .XName("x")
        .YName("y")
        .DataSource(ViewBag.vietnamData)
        .Name("Vietnam")
        .Marker(m => m.Visible(true))
        .LabelSettings(ls => ls.Visible(true))
        .Add();

    series.Type(Syncfusion.EJ2.Charts.ChartSeriesType.Line)
        .XName("x")
        .YName("y")
        .DataSource(ViewBag.indonesiaData)
        .Name("Indonesia")
        .Marker(m => m.Visible(true))
        .LabelSettings(ls => ls.Visible(true))
        .Add();

    series.Type(Syncfusion.EJ2.Charts.ChartSeriesType.Line)
        .XName("x")
        .YName("y")
        .DataSource(ViewBag.franceData)
        .Name("France")
        .Marker(m => m.Visible(true))
        .LabelSettings(ls => ls.Visible(true))
        .Add();

    series.Type(Syncfusion.EJ2.Charts.ChartSeriesType.Line)
        .XName("x")
        .YName("y")
        .DataSource(ViewBag.polandData)
        .Name("Poland")
        .Marker(m => m.Visible(true))
        .LabelSettings(ls => ls.Visible(true))
        .Add();

    series.Type(Syncfusion.EJ2.Charts.ChartSeriesType.Line)
        .XName("x")
        .YName("y")
        .DataSource(ViewBag.mexicoData)
        .Name("Mexico")
        .Marker(m => m.Visible(true))
        .LabelSettings(ls => ls.Visible(true))
        .Add();
})
.Render()