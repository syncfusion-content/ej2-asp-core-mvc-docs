<ejs-accumulationchart id="container">
    <e-accumulationchart-legendsettings visible="false">
    </e-accumulationchart-legendsettings>
    <e-accumulationchart-tooltipsettings enable="true" format = "${point.x:MMM yyyy} : <b>${point.y:n2}%</b>"></e-accumulationchart-tooltipsettings>
    <e-accumulation-series-collection>
        <e-accumulation-series dataSource="@ViewBag.dataSource" xName="x" yName="y" radius="100%">
        </e-accumulation-series>
    </e-accumulation-series-collection>
</ejs-accumulationchart>