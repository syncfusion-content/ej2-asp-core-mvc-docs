@using Syncfusion.EJ2.BlockEditor

<div id='blockeditor-container'>
    <ejs-blockeditor blocks="@ViewBag.BlockData" id="block-editor" fileUploading="fileUploading">
        <e-blockeditor-imagesettings saveUrl="[SERVICE_HOSTED_PATH]/api/Home/SaveImage" path="[SERVICE_HOSTED_PATH]/Uploads/"></e-blockeditor-imagesettings>
    </ejs-blockeditor>
</div>
<script>
    function fileUploading(args) {
        args.currentRequest.setRequestHeader('Authorization', 'Syncfusion');
    }
</script>
<style>
    #blockeditor-container {
        margin: 20px auto;
    }
</style>
