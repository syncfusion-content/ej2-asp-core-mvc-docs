@using Syncfusion.EJ2.BlockEditor

<div id='blockeditor-container'>
    <ejs-blockeditor transformSettings="@ViewBag.Transform" height="300px" blocks="@ViewBag.BlockData" id="block-editor">
        <e-blockeditor-inlinetoolbarsettings enable=true popupWidth="180px" items="@ViewBag.InlineToolbarItems"></e-blockeditor-inlinetoolbarsettings>
    </ejs-blockeditor>
</div>

<style>
    #blockeditor-container {
        margin: 20px auto;
    }
</style>
