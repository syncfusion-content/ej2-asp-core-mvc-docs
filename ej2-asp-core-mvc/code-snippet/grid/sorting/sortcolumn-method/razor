<div id="container">
    <div>
        @Html.EJS().Button("sortBtn").Content("Sort Order Date").CssClass("e-outline").Render()
        @Html.EJS().Button("clearSortBtn").Content("Clear All Sorting").CssClass("e-outline").Render()
        <span id="status"></span>
    </div>
    <div class="control-section">
        @Html.EJS().Grid("Grid").DataSource((IEnumerable<object>)ViewBag.DataSource).Height("280").AllowSorting(true).AllowMultiSorting(true).Columns(col =>
        {
            col.Field("OrderID").HeaderText("Order ID").TextAlign(Syncfusion.EJ2.Grids.TextAlign.Right).Width("100").Add();
            col.Field("CustomerID").HeaderText("Customer ID").Width("120").Add();
            col.Field("OrderDate").HeaderText("Order Date").Format("yMd").TextAlign(Syncfusion.EJ2.Grids.TextAlign.Right).Width("130").Add();
            col.Field("Freight").HeaderText("Freight").Format("C2").TextAlign(Syncfusion.EJ2.Grids.TextAlign.Right).Width("100").Add();
            col.Field("ShipCountry").HeaderText("Ship Country").Width("130").Add();
        }).Render()
    </div>
</div>

<script>
    document.getElementById('sortBtn').onclick = sortClick;
    document.getElementById('clearSortBtn').onclick = clearSortClick;

    function sortClick() {
        var grid = document.getElementById("Grid").ej2_instances[0];
        grid.sortColumn('OrderDate', 'Descending');
        document.getElementById('status').innerText = 'Sorted by Order Date (Descending)';
    }

    function clearSortClick() {
        var grid = document.getElementById("Grid").ej2_instances[0];
        grid.clearSorting();
        document.getElementById('status').innerText = 'All sorting cleared!';
    }
</script>

<style>
    .control-section{
        padding-top:20px;
    }
    #status{
        margin-left:10px;
        color:green;
    }
    #clearSortBtn{
        margin-left:8px;
    }
</style>