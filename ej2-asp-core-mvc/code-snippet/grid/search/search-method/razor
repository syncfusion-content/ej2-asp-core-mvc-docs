<div id="container">
    <div>
        @Html.EJS().TextBox("searchInput").Placeholder("Enter search text...").Width("150px").Render()
        @Html.EJS().Button("searchBtn").Content("Search").CssClass("e-outline").Render()
        <span id="status"></span>
    </div>
    <div class="control-section">
        @Html.EJS().Grid("Grid").DataSource((IEnumerable<object>)ViewBag.DataSource).Height("280").Columns(col =>
        {
            col.Field("OrderID").HeaderText("Order ID").TextAlign(Syncfusion.EJ2.Grids.TextAlign.Right).Width("100").Add();
            col.Field("CustomerID").HeaderText("Customer ID").Width("120").Add();
            col.Field("ShipCity").HeaderText("Ship City").Width("120").Add();
            col.Field("ShipCountry").HeaderText("Ship Country").Width("130").Add();
            col.Field("Freight").HeaderText("Freight").Format("C2").TextAlign(Syncfusion.EJ2.Grids.TextAlign.Right).Width("100").Add();
        }).Render()
    </div>
</div>

<script>
    document.getElementById('searchBtn').onclick = handleSearchClick;

    function handleSearchClick() {
        var grid = document.getElementById("Grid").ej2_instances[0];
        var searchText = document.getElementById("searchInput").ej2_instances[0].value;
        grid.search(searchText);
        document.getElementById('status').innerText = 'Search completed for: "' + searchText + '"';
    }
</script>

<style>
    .control-section {
        padding-top: 20px;
    }

    #searchInput {
        margin-right: 8px;
    }

    #status {
        margin-left: 10px;
        color: green;
    }
</style>