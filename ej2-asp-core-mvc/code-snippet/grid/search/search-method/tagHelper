<div id="container">
    <div>
        <ejs-textbox id="searchInput" placeholder="Enter search text..." width="150px"></ejs-textbox>
        <ejs-button id="searchBtn" content="Search" cssClass="e-outline"></ejs-button>
        <span id="status"></span>
    </div>
    <div class="control-section">
        <ejs-grid id="Grid" dataSource="@ViewBag.DataSource" height="280">
            <e-grid-columns>
                <e-grid-column field="OrderID" headerText="Order ID" textAlign="Right" width="100"></e-grid-column>
                <e-grid-column field="CustomerID" headerText="Customer ID" width="120"></e-grid-column>
                <e-grid-column field="ShipCity" headerText="Ship City" width="120"></e-grid-column>
                <e-grid-column field="ShipCountry" headerText="Ship Country" width="130"></e-grid-column>
                <e-grid-column field="Freight" headerText="Freight" format="C2" textAlign="Right" width="100"></e-grid-column>
            </e-grid-columns>
        </ejs-grid>
    </div>
</div>

<script>
    document.getElementById('searchBtn').onclick = handleSearchClick;

    function handleSearchClick(){
        var grid = document.getElementById("Grid").ej2_instances[0];
        var searchText = document.getElementById("searchInput").ej2_instances[0].value;
        grid.search(searchText);
        document.getElementById('status').innerText = 'Search completed for: "' + searchText + '"';
    }
</script>

<style>
    .control-section{
        padding-top:20px;
    }
    #searchInput{
        margin-right:8px;
    }
    #status{
        margin-left:10px;
        color:green;
    }
</style>