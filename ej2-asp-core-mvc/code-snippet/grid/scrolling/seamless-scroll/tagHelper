<ejs-grid id="grid" dataSource="@ViewBag.datasource" enableVirtualization="true" height="300" load="load">
    <e-grid-pageSettings pageSize=50></e-grid-pageSettings>
    <e-grid-columns>
        <e-grid-column field="TaskID" headerText="Task ID" textAlign="Right" isPrimaryKey="true" width="100"></e-grid-column>
        <e-grid-column field="Engineer" headerText="Engineer" width="100"></e-grid-column>
        <e-grid-column field="Designation" headerText="Designation" width="140"></e-grid-column>
        <e-grid-column field="Estimation" headerText="Estimation" textAlign="Right" width="110"></e-grid-column>
        <e-grid-column field="Status" headerText="Status" width="100"></e-grid-column>
    </e-grid-columns>
</ejs-grid>

<script>
    function load(args) {
        args.enableSeamlessScrolling = true;
    }
</script>