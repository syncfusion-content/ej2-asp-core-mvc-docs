@using Syncfusion.EJ2

<div style="margin-bottom: 10px">
    <label>Row Buffer: </label>
    <ejs-dropdownlist id="rowBufferDropdown" dataSource="@ViewBag.bufferSizes" value="5" change="changeBuffer">
        <e-dropdownlist-fields text="text" value="value"></e-dropdownlist-fields>
    </ejs-dropdownlist>
</div>

<ejs-grid id="Grid" dataSource="@ViewBag.dataSource" enableDomVirtualization="true" height="500">
    <e-grid-domvirtualizationsettings virtualDomType="Row" rowBuffer="5"></e-grid-domvirtualizationsettings>
    <e-grid-columns>
        <e-grid-column field="OrderID" headerText="Order ID" textAlign="Right" width="120"></e-grid-column>
        <e-grid-column field="CustomerID" headerText="Customer ID" width="150"></e-grid-column>
        <e-grid-column field="OrderDate" headerText="Order Date" format="yMd" width="150"></e-grid-column>
        <e-grid-column field="Freight" headerText="Freight" format="C2" textAlign="Right" width="120"></e-grid-column>
        <e-grid-column field="ShipCity" headerText="Ship City" width="150"></e-grid-column>
        <e-grid-column field="ShipCountry" headerText="Ship Country" width="150"></e-grid-column>
    </e-grid-columns>
</ejs-grid>

<script>
    function changeBuffer(args) {
        var grid = document.getElementById('Grid').ej2_instances[0];
        grid.domVirtualizationSettings.rowBuffer = args.value;
        grid.refresh();
    }
</script>
