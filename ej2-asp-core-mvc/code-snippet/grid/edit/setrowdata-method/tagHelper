<div id="container">
    <div>
        <ejs-button id="setCellBtn" content="Update Row Data of Order 10248" cssClass="e-outline"></ejs-button>
        <span id="status"></span>
    </div>
    <div class="control-section">
        <ejs-grid id="Grid" dataSource="@ViewBag.DataSource" height="240"
            toolbar="@(new List<string>(){ "Edit","Update","Cancel"})">
            <e-grid-editSettings allowEditing="true"></e-grid-editSettings>
            <e-grid-columns>
                <e-grid-column field="OrderID" headerText="Order ID" isPrimaryKey="true" textAlign="Right" width="100"></e-grid-column>
                <e-grid-column field="CustomerID" headerText="Customer ID" width="120"></e-grid-column>
                <e-grid-column field="ShipName" headerText="Ship Name" width="150"></e-grid-column>
                <e-grid-column field="ShipCity" headerText="Ship City" width="120"></e-grid-column>
                <e-grid-column field="Freight" headerText="Freight" format="C2" textAlign="Right" width="100"></e-grid-column>
            </e-grid-columns>
        </ejs-grid>
    </div>
</div>

<script>
    document.getElementById('setCellBtn').onclick = handleButtonClick;
    function handleButtonClick(){
        var grid = document.getElementById("Grid").ej2_instances[0];
        grid.setRowData(10248, {
            OrderID: 10248,
            CustomerID: 'VINET',
            ShipName: 'Speedy Express',
            ShipCity: 'Seattle',
            Freight: 99.99
        });
        document.getElementById('status').innerText = 'Row data updated successfully!';
    }
</script>

<style>
    .control-section{
        padding-top:20px;
    }
    #status{
        margin-left:10px;
        color:green;
    }
</style>