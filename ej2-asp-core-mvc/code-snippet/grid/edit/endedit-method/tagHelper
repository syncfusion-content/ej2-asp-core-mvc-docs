<div id="container">
    <div>
        <ejs-button id="startEditBtn" content="Start Edit (Row 0)" cssClass="e-outline"></ejs-button>
        <ejs-button id="endEditBtn" content="Save Edit (endEditAsync)" cssClass="e-outline"></ejs-button>
        <span id="status"></span>
    </div>
    <div class="control-section">
        <ejs-grid id="Grid" dataSource="@ViewBag.DataSource" height="280">
            <e-grid-editSettings allowEditing="true" mode="Normal"></e-grid-editSettings>
            <e-grid-columns>
                <e-grid-column field="OrderID" headerText="Order ID" isPrimaryKey="true" textAlign="Right" width="100"></e-grid-column>
                <e-grid-column field="CustomerID" headerText="Customer ID" width="120"></e-grid-column>
                <e-grid-column field="ShipCity" headerText="Ship City" width="120"></e-grid-column>
                <e-grid-column field="ShipCountry" headerText="Ship Country" width="130"></e-grid-column>
                <e-grid-column field="Freight" headerText="Freight" format="C2" textAlign="Right" editType="numericedit" width="100"></e-grid-column>
            </e-grid-columns>
        </ejs-grid>
    </div>
</div>

<script>
    document.getElementById('startEditBtn').onclick = startEditClick;
    document.getElementById('endEditBtn').onclick = endEditClick;

    function startEditClick(){
        var grid = document.getElementById("Grid").ej2_instances[0];
        grid.startEdit();
    }

    function endEditClick(){
        var grid = document.getElementById("Grid").ej2_instances[0];
        grid.endEdit();
        document.getElementById('status').innerText = 'Edit saved successfully!';
    }
</script>

<style>
    .control-section{
        padding-top:20px;
    }
    #endEditBtn{
        margin-left:8px;
    }
    #status{
        margin-left:10px;
        color:green;
    }
</style>