<div id="container">
    <div>
        @Html.EJS().Button("startEditBtn").Content("Start Edit (Row 0)").CssClass("e-outline").Render()
        @Html.EJS().Button("endEditBtn").Content("Save Edit (endEditAsync)").CssClass("e-outline").Render()
        <span id="status"></span>
    </div>
    <div class="control-section">
        @Html.EJS().Grid("Grid").DataSource((IEnumerable<object>)ViewBag.DataSource).Height("280").Columns(col =>
        {
            col.Field("OrderID").HeaderText("Order ID").IsPrimaryKey(true).TextAlign(Syncfusion.EJ2.Grids.TextAlign.Right).Width("100").Add();
            col.Field("CustomerID").HeaderText("Customer ID").Width("120").Add();
            col.Field("ShipCity").HeaderText("Ship City").Width("120").Add();
            col.Field("ShipCountry").HeaderText("Ship Country").Width("130").Add();
            col.Field("Freight").HeaderText("Freight").Format("C2").EditType("numericedit")
            .TextAlign(Syncfusion.EJ2.Grids.TextAlign.Right).Width("100").Add();
        }).EditSettings(edit =>
        {
            edit.AllowEditing(true).Mode(Syncfusion.EJ2.Grids.EditMode.Normal);
        }).Render()
    </div>
</div>

<script>
    document.getElementById('startEditBtn').onclick = startEditClick;
    document.getElementById('endEditBtn').onclick = endEditClick;

    function startEditClick() {
        var grid = document.getElementById("Grid").ej2_instances[0];
        grid.startEdit();
    }

    function endEditClick() {
        var grid = document.getElementById("Grid").ej2_instances[0];
        grid.endEdit();
        document.getElementById('status').innerText = 'Edit saved successfully!';
    }
</script>

<style>
    .control-section {
        padding-top: 20px;
    }

    #endEditBtn {
        margin-left: 8px;
    }

    #status {
        margin-left: 10px;
        color: green;
    }
</style>
