<div id="container">
    <div>
        <ejs-button id="addBtn" content="Add New Record" cssClass="e-outline"></ejs-button>
        <span id="status"></span>
    </div>
    <div class="control-section">
        <ejs-grid id="Grid" dataSource="@ViewBag.DataSource" height="180"
            toolbar="@(new List<string>(){ "Add","Edit","Delete","Update","Cancel"})">
            <e-grid-editSettings allowAdding="true" allowEditing="true" allowDeleting="true"></e-grid-editSettings>
            <e-grid-columns>
                <e-grid-column field="OrderID" headerText="Order ID" isPrimaryKey="true" textAlign="Right" width="100"></e-grid-column>
                <e-grid-column field="CustomerID" headerText="Customer ID" width="120"></e-grid-column>
                <e-grid-column field="ShipCity" headerText="Ship City" width="120"></e-grid-column>
                <e-grid-column field="ShipCountry" headerText="Ship Country" width="130"></e-grid-column>
                <e-grid-column field="Freight" headerText="Freight" format="C2" textAlign="Right" width="100"></e-grid-column>
            </e-grid-columns>
        </ejs-grid>
    </div>
</div>

<script>
    document.getElementById('addBtn').onclick = handleAddClick;
    function handleAddClick(){
        var grid = document.getElementById("Grid").ej2_instances[0];
        grid.addRecord({
            OrderID: Math.floor(Math.random() * 100000),
            CustomerID: 'ALFKI',
            ShipCity: 'Berlin',
            ShipCountry: 'Germany',
            Freight: 29.50
        });
        document.getElementById('status').innerText = 'Record added successfully!';
    }
</script>

<style>
    .control-section{
        padding-top:20px;
    }
    #status{
        margin-left:10px;
        color:green;
    }
</style>