<div id="container">
    <div>
        @Html.EJS().Button("deleteBtn").Content("Delete Order ID 10248").CssClass("e-outline").Render()
        @Html.EJS().Button("deleteRowBtn").Content("Delete First Row (by TR element)").CssClass("e-outline").Render()
        <span id="status"></span>
    </div>
    <div class="control-section">
        @Html.EJS().Grid("Grid").DataSource((IEnumerable<object>)ViewBag.DataSource).Height("180").Columns(col =>
        {
            col.Field("OrderID").HeaderText("Order ID").IsPrimaryKey(true).TextAlign(Syncfusion.EJ2.Grids.TextAlign.Right).Width("100").Add();
            col.Field("CustomerID").HeaderText("Customer ID").Width("120").Add();
            col.Field("ShipCity").HeaderText("Ship City").Width("120").Add();
            col.Field("ShipCountry").HeaderText("Ship Country").Width("130").Add();
            col.Field("Freight").HeaderText("Freight").Format("C2").TextAlign(Syncfusion.EJ2.Grids.TextAlign.Right).Width("100").Add();
        }).EditSettings(edit => { edit.AllowDeleting(true); }).Render()
    </div>
</div>

<script>
    document.getElementById('deleteBtn').onclick = deleteById;
    document.getElementById('deleteRowBtn').onclick = deleteFirstRow;

    function deleteById() {
        var grid = document.getElementById("Grid").ej2_instances[0];
        grid.deleteRecord('OrderID', { OrderID: 10248 });
        document.getElementById('status').innerText = 'Record with Order ID 10248 deleted!';
    }

    function deleteFirstRow() {
        var grid = document.getElementById("Grid").ej2_instances[0];
        var rowElement = grid.getRowByIndex(0);
        grid.deleteRow(rowElement);
        document.getElementById('status').innerText = 'First row deleted using deleteRowAsync!';
    }
</script>

<style>
    .control-section {
        padding-top: 20px;
    }

    #deleteRowBtn {
        margin-left: 8px;
    }

    #status {
        margin-left: 10px;
        color: green;
    }
</style>
