<div id="container">
    <div>
        <ejs-button id="deleteBtn" content="Delete Order ID 10248" cssClass="e-outline"></ejs-button>
        <ejs-button id="deleteRowBtn" content="Delete First Row (by TR element)" cssClass="e-outline"></ejs-button>
        <span id="status"></span>
    </div>
    <div class="control-section">
        <ejs-grid id="Grid" dataSource="@ViewBag.DataSource" height="180">
            <e-grid-editSettings allowDeleting="true"></e-grid-editSettings>
            <e-grid-columns>
                <e-grid-column field="OrderID" headerText="Order ID" isPrimaryKey="true" textAlign="Right" width="100"></e-grid-column>
                <e-grid-column field="CustomerID" headerText="Customer ID" width="120"></e-grid-column>
                <e-grid-column field="ShipCity" headerText="Ship City" width="120"></e-grid-column>
                <e-grid-column field="ShipCountry" headerText="Ship Country" width="130"></e-grid-column>
                <e-grid-column field="Freight" headerText="Freight" format="C2" textAlign="Right" width="100"></e-grid-column>
            </e-grid-columns>
        </ejs-grid>
    </div>
</div>

<script>
    document.getElementById('deleteBtn').onclick = deleteById;
    document.getElementById('deleteRowBtn').onclick = deleteFirstRow;

    function deleteById(){
        var grid = document.getElementById("Grid").ej2_instances[0];
        grid.deleteRecord('OrderID', { OrderID: 10248 });
        document.getElementById('status').innerText = 'Record with Order ID 10248 deleted!';
    }

    function deleteFirstRow(){
        var grid = document.getElementById("Grid").ej2_instances[0];
        var rowElement = grid.getRowByIndex(0);
        grid.deleteRow(rowElement);
        document.getElementById('status').innerText = 'First row deleted using deleteRowAsync!';
    }
</script>

<style>
    .control-section{
        padding-top:20px;
    }
    #deleteRowBtn{
        margin-left:8px;
    }
    #status{
        margin-left:10px;
        color:green;
    }
</style>