<div id="container">
    <div>
        <ejs-button id="groupBtn" content="Group by Ship Country" cssClass="e-outline"></ejs-button>
        <ejs-button id="ungroupBtn" content="Ungroup Ship Country" cssClass="e-outline"></ejs-button>
        <ejs-button id="clearGroupBtn" content="Clear All Grouping" cssClass="e-outline"></ejs-button>
        <span id="status"></span>
    </div>
    <div class="control-section">
        <ejs-grid id="Grid" dataSource="@ViewBag.DataSource" height="200" allowGrouping="true">
            <e-grid-columns>
                <e-grid-column field="OrderID" headerText="Order ID" textAlign="Right" width="100"></e-grid-column>
                <e-grid-column field="CustomerID" headerText="Customer ID" width="120"></e-grid-column>
                <e-grid-column field="ShipCity" headerText="Ship City" width="120"></e-grid-column>
                <e-grid-column field="ShipCountry" headerText="Ship Country" width="130"></e-grid-column>
                <e-grid-column field="Freight" headerText="Freight" format="C2" textAlign="Right" width="100"></e-grid-column>
            </e-grid-columns>
        </ejs-grid>
    </div>
</div>

<script>
    document.getElementById('groupBtn').onclick = groupColumn;
    document.getElementById('ungroupBtn').onclick = ungroupColumn;
    document.getElementById('clearGroupBtn').onclick = clearGrouping;

    function groupColumn(){
        var grid = document.getElementById("Grid").ej2_instances[0];
        grid.groupColumn('ShipCountry');
        document.getElementById('status').innerText = 'Grouped by Ship Country!';
    }

    function ungroupColumn(){
        var grid = document.getElementById("Grid").ej2_instances[0];
        grid.ungroupColumn('ShipCountry');
        document.getElementById('status').innerText = 'Ungrouped Ship Country column!';
    }

    function clearGrouping(){
        var grid = document.getElementById("Grid").ej2_instances[0];
        grid.clearGrouping();
        document.getElementById('status').innerText = 'All grouping cleared!';
    }
</script>

<style>
    .control-section{
        padding-top:20px;
    }
    #ungroupBtn, #clearGroupBtn{
        margin-left:8px;
    }
    #status{
        margin-left:10px;
        color:green;
    }
</style>