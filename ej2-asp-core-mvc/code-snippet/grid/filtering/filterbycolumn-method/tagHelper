<div id="container">
    <div>
        <ejs-button id="filterBtn" content="Filter Customer ID = HANAR" cssClass="e-outline"></ejs-button>
        <ejs-button id="clearAllBtn" content="Clear All Filters" cssClass="e-outline"></ejs-button>
        <span id="status"></span>
    </div>
    <div class="control-section">
        <ejs-grid id="Grid" dataSource="@ViewBag.DataSource" height="180" allowFiltering="true">
            <e-grid-columns>
                <e-grid-column field="OrderID" headerText="Order ID" textAlign="Right" width="100"></e-grid-column>
                <e-grid-column field="CustomerID" headerText="Customer ID" width="120"></e-grid-column>
                <e-grid-column field="ShipCity" headerText="Ship City" width="120"></e-grid-column>
                <e-grid-column field="ShipCountry" headerText="Ship Country" width="130"></e-grid-column>
                <e-grid-column field="Freight" headerText="Freight" format="C2" textAlign="Right" width="100"></e-grid-column>
            </e-grid-columns>
        </ejs-grid>
    </div>
</div>

<script>
    document.getElementById('filterBtn').onclick = handleFilterClick;
    document.getElementById('clearAllBtn').onclick = handleClearFilterClick;

    function handleFilterClick(){
        var grid = document.getElementById("Grid").ej2_instances[0];
        grid.filterByColumn('CustomerID','equal','HANAR');
        document.getElementById('status').innerText = 'Filter applied on Customer ID = HANAR';
    }

    function handleClearFilterClick(){
        var grid = document.getElementById("Grid").ej2_instances[0];
        grid.clearFiltering();
        document.getElementById('status').innerText = 'All filters cleared!';
    }
</script>

<style>
    .control-section{
        padding-top:20px;
    }
    #clearAllBtn{
        margin-left:8px;
    }
    #status{
        margin-left:10px;
        color:green;
    }
</style>