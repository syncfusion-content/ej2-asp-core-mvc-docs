@using Syncfusion.EJ2.Schedule

<ejs-schedule id="schedule" height="550" selectedDate="new DateTime(2026, 6, 15)">
    <e-schedule-views>
        <e-schedule-view option="Day" maxEventStack="2"></e-schedule-view>
        <e-schedule-view option="Week" maxEventStack="2"></e-schedule-view>
        <e-schedule-view option="WorkWeek" maxEventStack="2"></e-schedule-view>
    </e-schedule-views>
    <e-schedule-eventsettings dataSource="@ViewBag.appointments"></e-schedule-eventsettings>
</ejs-schedule>