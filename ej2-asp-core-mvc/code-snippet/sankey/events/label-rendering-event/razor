@Html.EJS().Sankey("sankey-container")
    .Width("90%")
    .Height("450px")
    .Tooltip(t => t.Enable(true))
    .LegendSettings(l => l.Visible(true))
    .LabelRendering("onSankeyLabelRendering")
    .Nodes(ViewBag.SankeyNodes)
    .Links(ViewBag.SankeyLinks)
    .Render()

<script>
    function onSankeyLabelRendering(args) {
        args.labelStyle = {
            fontFamily: 'Arial',
            fontStyle: 'normal',
            fontWeight: 'bold',
            fontSize: '12px',
            color: '#000'
        };
    }
</script>