@{
    // Mirroring React's id="sankey-container"
    var sankeyId = "sankey-container";
}

@Html.EJS().Sankey(sankeyId)
    .Width("90%")
    .Height("450px")
    .Nodes(ViewBag.SankeyNodes)
    .Links(ViewBag.SankeyLinks)
    .Tooltip(t => t.Enable(true))
    .LegendSettings(l => l.Visible(true))
    .NodeRendering("onNodeRendering")
    .Render()

<script>
    // Mirrors React's nodeRendering: set node color based on node id
    function onNodeRendering(args) {
        // args.node contains the node info
        if (args && args.node && args.node.id === 'Agricultural Waste') {
            args.node.color = '#FF6B6B';
        } else if (args && args.node && args.node.id === 'Bio-conversion') {
            args.node.color = '#4ECDC4';
        }
    }
</script>