@Html.EJS().Sankey("sankey-container")
    .Width("90%")
    .Height("450px")
    .Tooltip(t => t.Enable(true)
        .Fill((string)ViewBag.TooltipFill)
        .TextStyle(ts => ts
            .FontFamily((string)ViewBag.TooltipFontFamily)
            .FontStyle((string)ViewBag.TooltipFontStyle)
            .FontWeight((string)ViewBag.TooltipFontWeight)
            .FontSize((string)ViewBag.TooltipFontSize)
            .Color((string)ViewBag.TooltipColor)
        )
    )
    .LegendSettings(l => l.Visible(true))
    .Nodes(ViewBag.SankeyNodes)
    .Links(ViewBag.SankeyLinks)
    .Render()