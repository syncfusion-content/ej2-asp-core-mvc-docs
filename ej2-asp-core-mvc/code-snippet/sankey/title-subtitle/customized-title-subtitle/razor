@Html.EJS().Sankey("sankey-container")
    .Width("90%")
    .Height("450px")
    .Title("Energy Flow Diagram")
    .SubTitle("Agricultural Energy Conversion")
    .TitleStyle(ts => ts
        .FontFamily((string)ViewBag.TitleFontFamily)
        .FontStyle((string)ViewBag.TitleFontStyle)
        .FontWeight((string)ViewBag.TitleFontWeight)
        .Size((string)ViewBag.TitleSize)
        .Color((string)ViewBag.TitleColor)
    )
    .SubTitleStyle(ss => ss
        .FontFamily((string)ViewBag.SubTitleFontFamily)
        .FontStyle((string)ViewBag.SubTitleFontStyle)
        .FontWeight((string)ViewBag.SubTitleFontWeight)
        .Size((string)ViewBag.SubTitleSize)
        .Color((string)ViewBag.SubTitleColor)
    )
    .Nodes(ViewBag.SankeyNodes)
    .Links(ViewBag.SankeyLinks)
    .Tooltip(t => t.Enable(true))
    .LegendSettings(l => l.Visible(true))
    .Render()