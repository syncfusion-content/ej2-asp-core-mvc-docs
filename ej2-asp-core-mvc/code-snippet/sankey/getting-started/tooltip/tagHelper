<ejs-sankey id="sankey-container" width="90%" height="450px"
    title="California Energy Consumption in 2023"
    sub-title="Source: Lawrence Livermore National Laboratory"
    loaded="onSankeyLoaded">
    <e-sankey-nodes>
        @foreach (var node in ViewBag.SankeyNodes)
        {
            <e-sankey-node id="@node.Id" offset="@(node.Offset ?? 0)"></e-sankey-node>
        }
    </e-sankey-nodes>
    <e-sankey-links>
        @foreach (var link in ViewBag.SankeyLinks)
        {
            <e-sankey-link source-id="@link.SourceId" target-id="@link.TargetId" value="@link.Value"></e-sankey-link>
        }
    </e-sankey-links>
    <e-sankey-linksettings opacity="0.6" curvature="0.55" color-type="Source"></e-sankey-linksettings>
    <e-sankey-labelsettings visible="true"></e-sankey-labelsettings>
    <e-sankey-tooltipsettings enable="true"></e-sankey-tooltipsettings>
    <e-sankey-legendsettings visible="true" position="Bottom" item-padding="8"></e-sankey-legendsettings>
</ejs-sankey>

<script>
    function onSankeyLoaded(args) {
        // Clear title attribute if needed
        var element = document.getElementById('sankey');
        if (element) element.setAttribute('title', '');

        // Responsive height for mobile/tablet
        var isDevice = /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent);
        if (isDevice) {
            args.sankey.height = '600px';
        } else {
            args.sankey.height = '450px';
        }
        args.sankey.refresh();
    }
</script>