<ejs-sankey id="sankey-container" width="90%" height="450px"
    title="California Energy Consumption in 2023"
    subTitle="Source: Lawrence Livermore National Laboratory"
    loaded="onSankeyLoaded">
    <e-sankey-nodes>
        @foreach (var node in ViewBag.SankeyNodes)
        {
            <e-sankey-node id="@node.Id" offset="@(node.Offset ?? 0)"></e-sankey-node>
        }
    </e-sankey-nodes>
    <e-sankey-links>
        @foreach (var link in ViewBag.SankeyLinks)
        {
            <e-sankey-link sourceId="@link.SourceId" targetId="@link.TargetId" value="@link.Value"></e-sankey-link>
        }
    </e-sankey-links>
    <e-sankey-linksettings opacity="0.6" curvature="0.55" colorType="Source"></e-sankey-linksettings>
    <e-sankey-labelsettings visible="true"></e-sankey-labelsettings>
    <e-sankey-tooltipsettings enable="true"></e-sankey-tooltipsettings>
    <e-sankey-legendsettings visible="true" position="Bottom" itemPadding="8"></e-sankey-legendsettings>
</ejs-sankey>

<script>
    function onSankeyLoaded(args) {
        var element = document.getElementById('sankey-container');
        if (element) element.setAttribute('title', '');
    }
</script>