@{
    // Mirroring React's id="sankey-container"
    var sankeyId = "sankey-container";
}

@Html.EJS().Sankey(sankeyId)
    .Width("90%")
    .Height("450px")
    .LinkStyle(ls => ls.Opacity(0.5).Curvature(0.4))
    .Nodes(ViewBag.SankeyNodes)
    .Links(ViewBag.SankeyLinks)
    .Tooltip(t => t.Enable(true))
    .LegendSettings(l => l.Visible(true))
    .Render()