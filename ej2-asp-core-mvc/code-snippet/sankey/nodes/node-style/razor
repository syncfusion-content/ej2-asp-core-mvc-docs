@Html.EJS().Sankey("sankey-container")
    .Width("90%")
    .Height("450px")
    .NodeStyle(ns => ns
        .Fill((string)ViewBag.NodeFill)
        .Opacity(Convert.ToDouble(ViewBag.NodeOpacity))
        .Width(Convert.ToInt32(ViewBag.NodeWidth))
        .Stroke((string)ViewBag.NodeBorderColor)
        .StrokeWidth(Convert.ToDouble(ViewBag.NodeBorderWidth)
        )
    )
    .Tooltip(t => t.Enable(true))
    .LegendSettings(l => l.Visible(true))
    .Nodes(ViewBag.SankeyNodes)
    .Links(ViewBag.SankeyLinks)
    .Render()