@{
    var sankeyId = "sankey-container";
}

@Html.EJS().Sankey(sankeyId)
    .Width("90%")
    .Height("450px")
    .NodeStyle(ns => ns
        .Opacity(Convert.ToDouble(ViewBag.NodeOpacity))
        .HighlightOpacity(Convert.ToDouble(ViewBag.NodeHighlightOpacity))
        .InactiveOpacity(Convert.ToDouble(ViewBag.NodeInactiveOpacity))
    )
    .Nodes(ViewBag.SankeyNodes)
    .Links(ViewBag.SankeyLinks)
    .Tooltip(t => t.Enable(true))
    .LegendSettings(l => l.Visible(true))
    .Render()