@Html.EJS().Sankey("sankey-container")
    .Width("90%")
    .Height("450px")
    .Tooltip(tooltip => tooltip.Enable(true))
    .LegendSettings(legend => legend.Visible(true))
    .LabelSettings(label => label.Visible(false))
    .Nodes(ViewBag.SankeyNodes)
    .Links(ViewBag.SankeyLinks)
    .Render()