@Html.EJS().Sankey("sankey-container")
    .Width("90%")
    .Height("450px")
    .Tooltip(t => t.Enable(true))
    .LegendSettings(l => l.Visible(true))
    .LinkRendering("onSankeyLinkRendering")
    .Nodes(ViewBag.SankeyNodes)
    .Links(ViewBag.SankeyLinks)
    .Render()

<script>
    function onSankeyLinkRendering(args) {
        var link = args.link || args.data || {};
        var src = link.sourceId, tgt = link.targetId;
        if (src === 'Bio-conversion' && tgt === 'Heat') {
            args.fill = '#FF6B6B';
        } else {
            args.fill = '#599dbd';
        }
    }
</script>